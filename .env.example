# Variáveis de ambiente do backend CuidarJuntos
# Copie para .env e preencha os valores. NUNCA versione o .env real.

# Assistente de IA (Anthropic) — necessária para o endpoint POST /api/v1/chat/.
# Sem esta chave, o chat responde HTTP 503 com mensagem amigável.
ANTHROPIC_API_KEY=

# Opcional: sobrescreve o modelo Claude usado pelo assistente.
# Padrão: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=
